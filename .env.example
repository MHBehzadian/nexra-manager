# ---------------------------------------------------------------------------
# Telegram Automation — environment configuration
# Copy this file to `.env` OR just run `python main.py` and use the setup wizard.
# ---------------------------------------------------------------------------

# From https://my.telegram.org  ->  API development tools
API_ID=
API_HASH=

# From @BotFather
BOT_TOKEN=

# Your numeric Telegram user id (get it from @userinfobot)
ADMIN_ID=

# Numbers channel (PNUMBERS). Optional — can also be set from the bot or via
# `python main.py set-channel <value>`. Accepts a @username, a numeric id
# (e.g. -1001234567890), or an invite link.
CHANNEL_ID=

# Optional second channel where the bot ALSO posts reports/backups/notices.
# Set from the bot or via `python main.py set-report-channel <value>`.
# The bot must be an admin of this channel.
REPORT_CHANNEL_ID=

# Optional: logging level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
